{
  "manifest_version": 3,
  "name": "Markdown Browser",
  "version": "2.1.0",
  "description": "Read, write, and search local markdown files. Inline editing, wiki-links, callout blocks, full-text search — 100% offline & private.",
  "homepage_url": "https://markdownbrowser.abhikuchbhi.in",
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": [
        "file://**/*.md",
        "file://**/*.mdx",
        "file://**/*.markdown",
        "file://**/*.mdown",
        "file://**/*.mkd"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Markdown Browser",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["app.html", "app.css", "app.js", "lib/*", "icons/*"],
      "matches": ["file:///*", "<all_urls>"]
    }
  ]
}
